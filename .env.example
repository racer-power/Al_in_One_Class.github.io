# ─────────────────────────────────────────────
# 로컬 개발용 환경 변수 (Git에 올리지 마세요)
# 사용법: 이 파일을 복사하여 .env 로 저장 후 값을 입력하세요.
#   copy .env.example .env
# ─────────────────────────────────────────────

# Google Apps Script 프로젝트 ID (clasp 사용 시)
# Apps Script URL: https://script.google.com/home/projects/{SCRIPT_ID}/edit
SCRIPT_ID=

# Google 스프레드시트 ID (스프레드시트 URL의 /d/ 와 /edit 사이)
# 스프레드시트에 Apps Script가 바인딩되어 있으면 생략 가능
SPREADSHEET_ID=

# 웹앱 배포 URL (학생 접속 주소 — 코드에서 사용하지 않음, 참고용)
WEBAPP_DEPLOYMENT_URL=

# Google Drive 서명 저장 폴더 이름 (기본값: 학급운영_서명보관)
DRIVE_FOLDER_NAME=학급운영_서명보관

# 서명 이미지 공유 반영 대기 시간(ms) (기본값: 1500)
IMAGE_LOAD_DELAY_MS=1500
